[Unit]
Description=Salt Security Agent - Celery Beat scheduler
Documentation=https://github.com/
After=network.target redis.service salt-security-agent-worker.service
Wants=redis.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/etc/salt-security-agent
ExecStart=/opt/salt-security-agent/venv/bin/salt-security-agent beat --config /etc/salt-security-agent/config.toml --loglevel INFO
Restart=on-failure
RestartSec=5

KillMode=mixed
TimeoutStopSec=30

# Hardening. Beat writes its schedule database; by default Celery places it
# in the working directory (celerybeat-schedule). Adjust ReadWritePaths if
# you point Beat at a different location.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadOnlyPaths=/etc/salt-security-agent /srv/salt-security-agent
ReadWritePaths=/srv/salt-security-reports /root/.local

[Install]
WantedBy=multi-user.target
